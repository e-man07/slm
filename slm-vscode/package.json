{
  "name": "slm-vscode",
  "displayName": "Sealevel - Solana Language Model",
  "description": "Solana-specialized AI assistant. Chat, inline autocomplete, explain transactions, decode errors.",
  "version": "0.1.0",
  "publisher": "slm",
  "license": "MIT",
  "icon": "resources/icon.png",
  "homepage": "https://slm.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/kshitij-hash/slm.git",
    "directory": "slm-vscode"
  },
  "bugs": {
    "url": "https://github.com/kshitij-hash/slm/issues"
  },
  "keywords": [
    "solana",
    "anchor",
    "rust",
    "ai",
    "copilot",
    "llm",
    "blockchain",
    "web3",
    "smart-contract",
    "autocomplete"
  ],
  "galleryBanner": {
    "color": "#0C0F14",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Programming Languages", "Machine Learning", "Snippets"],
  "activationEvents": [
    "onLanguage:rust",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:toml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "slm.chat",
        "name": "slm",
        "fullName": "Sealevel - Solana Language Model",
        "description": "Solana coding AI that actually knows Solana",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "slm.explainError",
        "title": "Sealevel: Explain Error Code"
      },
      {
        "command": "slm.explainTx",
        "title": "Sealevel: Explain Transaction"
      }
    ],
    "configuration": {
      "title": "Sealevel",
      "properties": {
        "slm.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Sealevel API key"
        },
        "slm.apiUrl": {
          "type": "string",
          "default": "https://slm.dev/api",
          "description": "Sealevel API base URL"
        },
        "slm.mode": {
          "type": "string",
          "enum": ["quality", "fast"],
          "default": "quality",
          "description": "Model mode: 'quality' for best results, 'fast' for speed"
        },
        "slm.autocomplete.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Sealevel inline code completions for Solana/Anchor files"
        },
        "slm.autocomplete.debounceMs": {
          "type": "number",
          "default": 1500,
          "description": "Delay in ms before triggering autocomplete after typing stops"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
