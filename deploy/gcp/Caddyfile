api.sealevel.tech {
	# Chat completions → Vercel (for auth, rate limiting, usage tracking)
	handle /v1/chat/completions {
		rewrite * /api/chat
		reverse_proxy https://sealevel.tech {
			header_up Host sealevel.tech
		}
	}

	# Explain endpoints → Vercel
	handle /api/explain/* {
		reverse_proxy https://sealevel.tech {
			header_up Host sealevel.tech
		}
	}

	# Usage stats → Vercel
	handle /api/usage {
		reverse_proxy https://sealevel.tech {
			header_up Host sealevel.tech
		}
	}

	# RAG query (no usage tracking needed)
	handle /query {
		reverse_proxy {$RAG_URL}
	}
	handle /health {
		reverse_proxy {$RAG_URL}
	}

	# CORS
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization"
	}
	@options method OPTIONS
	respond @options 204
}

mcp.sealevel.tech {
	reverse_proxy mcp:8080
}
